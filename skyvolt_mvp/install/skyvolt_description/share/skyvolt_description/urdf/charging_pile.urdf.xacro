<?xml version="1.0"?>
<!--
  Box-type charging pile (paper Fig.2). Carried by the robot; rests on
  a fixed support point with a power socket.
-->
<robot name="charging_pile" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:arg name="pile_id" default="p0"/>
  <xacro:property name="pile_id" value="$(arg pile_id)"/>

  <link name="${pile_id}/body">
    <visual>
      <geometry><box size="0.30 0.20 0.40"/></geometry>
      <material name="pile_green"><color rgba="0.20 0.65 0.30 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.30 0.20 0.40"/></geometry>
    </collision>
    <inertial>
      <mass value="6.0"/>
      <inertia ixx="0.10" ixy="0" ixz="0" iyy="0.10" iyz="0" izz="0.06"/>
    </inertial>
  </link>

  <!-- Latch hole at top so the robot's latch can engage -->
  <link name="${pile_id}/latch_hole"/>
  <joint name="${pile_id}/latch_hole_mount" type="fixed">
    <parent link="${pile_id}/body"/>
    <child  link="${pile_id}/latch_hole"/>
    <origin xyz="0 0 0.20"/>
  </joint>
</robot>
